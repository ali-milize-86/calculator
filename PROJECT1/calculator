history = []
print("====== Calculator ======")
print("Enter a sign (+, -, *, /)")
print("Commands: h = history, s = save, l = load, q = quit")
while True:
        mathsign = input("Enter your sign: ")
        if mathsign == "h":
            for item in history:
                print(item)
            continue
        if mathsign == "q":
            break
        for i in mathsign:
            if i in "abcdefgijklmnoprstuvwyxyzABCDEFGIJKLMNOPRSTUVWXYZ1234567890":
                print("Invalid math sign")
                break


        if mathsign == "s":
            savefile = open("calculatorfile.txt", "w")
            for theitem in history:
                savefile.write(theitem + "\n")
            savefile.close()
            continue

        if mathsign == "l":
            loadfile = open("calculatorfile.txt", "r")
            for loadeditem in loadfile:
                print(loadeditem)
            loadfile.close()
            continue


        while True:
            try:
                firstnumber = float(input("Enter the first digit: "))
                break
            except ValueError:
                print("Invalid! Please enter a number.")
        while True:   
            try:
                secondnumber = float(input("Enter the second digit: "))
                break
            except ValueError:
                print("Digit cannot contain letters!")

        if mathsign == "+":
            history.append(str(firstnumber) + " " + mathsign + " " + str(secondnumber) + " " + "=" + " "  + str(firstnumber + secondnumber))
            print("Result: " + str(firstnumber + secondnumber))
        elif mathsign == "/":
            try:
                history.append(str(firstnumber) + " " + mathsign + " " + str(secondnumber) + " " + "=" + " "  + str(firstnumber / secondnumber))
                print("Result: " + str(firstnumber / secondnumber))
            except:
                print("Cant divide by zero!")
        elif mathsign == "*":
            history.append(str(firstnumber) + " " + mathsign + " " + str(secondnumber) + " " + "=" + " "  + str(firstnumber * secondnumber))
            print("Result: " + str(firstnumber * secondnumber))
        elif mathsign == "-":
            history.append(str(firstnumber) + " " + mathsign + " " + str(secondnumber) + " " + "=" + " "  + str(firstnumber - secondnumber))
            print("Result: " + str(firstnumber - secondnumber))
            